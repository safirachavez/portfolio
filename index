<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & BASE ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #f5f2ec;
      --bg2:       #edeae2;
      --surface:   #ffffff;
      --border:    #d8d4ca;
      --ink:       #1a1814;
      --ink2:      #6b6760;
      --ink3:      #9e9b96;
      --accent:    #c1440e;
      --accent2:   #e8693a;
      --user-bg:   #1a1814;
      --user-ink:  #f5f2ec;
      --radius:    14px;
      --mono:      'DM Mono', monospace;
      --serif:     'DM Serif Display', serif;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--mono);
      font-size: 14px;
      line-height: 1.6;
    }

    /* ── LAYOUT ───────────────────────────────────────── */
    .app {
      display: grid;
      grid-template-columns: 300px 1fr;
      height: 100vh;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* ── SIDEBAR ──────────────────────────────────────── */
    .sidebar {
      background: var(--bg2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 40px 28px 28px;
      overflow-y: auto;
    }

    .avatar-wrap {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--border);
      overflow: hidden;
      margin-bottom: 20px;
      flex-shrink: 0;
    }

    .avatar-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .avatar-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: var(--ink3);
      font-family: var(--serif);
    }

    .sidebar-name {
      font-family: var(--serif);
      font-size: 22px;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 4px;
    }

    .sidebar-role {
      font-size: 11px;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 16px;
    }

    .sidebar-tagline {
      font-size: 13px;
      color: var(--ink2);
      line-height: 1.5;
      margin-bottom: 28px;
      font-style: italic;
    }

    .sidebar-divider {
      height: 1px;
      background: var(--border);
      margin: 20px 0;
    }

    .sidebar-section-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--ink3);
      margin-bottom: 12px;
    }

    .skills-group { margin-bottom: 18px; }

    .skills-group-name {
      font-size: 11px;
      color: var(--ink2);
      margin-bottom: 6px;
    }

    .skills-list {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .skill-tag {
      font-size: 10px;
      padding: 3px 8px;
      border: 1px solid var(--border);
      border-radius: 99px;
      color: var(--ink2);
      background: var(--surface);
    }

    .sidebar-links {
      margin-top: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar-link {
      font-size: 12px;
      color: var(--ink2);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: color 0.15s;
    }

    .sidebar-link:hover { color: var(--accent); }

    .sidebar-link .link-icon {
      width: 16px;
      text-align: center;
      font-style: normal;
    }

    /* ── MAIN CHAT ────────────────────────────────────── */
    .main {
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* ── HEADER ───────────────────────────────────────── */
    .header {
      padding: 20px 32px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      background: var(--surface);
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22c55e;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .header-title {
      font-size: 13px;
      color: var(--ink2);
    }

    .header-title strong { color: var(--ink); }

    .clear-btn {
      font-size: 11px;
      color: var(--ink3);
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--mono);
      transition: all 0.15s;
    }

    .clear-btn:hover { border-color: var(--ink2); color: var(--ink2); }

    /* ── MESSAGES ─────────────────────────────────────── */
    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      scroll-behavior: smooth;
    }

    .messages::-webkit-scrollbar { width: 4px; }
    .messages::-webkit-scrollbar-track { background: transparent; }
    .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* ── WELCOME ──────────────────────────────────────── */
    .welcome {
      text-align: center;
      padding: 60px 20px 20px;
      animation: fadeUp 0.5s ease both;
    }

    .welcome-headline {
      font-family: var(--serif);
      font-size: 36px;
      color: var(--ink);
      margin-bottom: 10px;
      line-height: 1.1;
    }

    .welcome-sub {
      font-size: 13px;
      color: var(--ink2);
      margin-bottom: 32px;
    }

    .suggestions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
    }

    .suggestion-chip {
      font-size: 12px;
      padding: 8px 16px;
      border: 1px solid var(--border);
      border-radius: 99px;
      background: var(--surface);
      color: var(--ink2);
      cursor: pointer;
      font-family: var(--mono);
      transition: all 0.15s;
    }

    .suggestion-chip:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--bg);
    }

    /* ── MESSAGE BUBBLES ──────────────────────────────── */
    .message {
      display: flex;
      gap: 12px;
      animation: fadeUp 0.3s ease both;
      max-width: 720px;
    }

    .message.user {
      align-self: flex-end;
      flex-direction: row-reverse;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .msg-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-style: normal;
      margin-top: 2px;
    }

    .message.assistant .msg-avatar {
      background: var(--accent);
      color: white;
      font-family: var(--serif);
      font-size: 16px;
    }

    .message.user .msg-avatar {
      background: var(--ink);
      color: var(--bg);
      font-size: 12px;
    }

    .bubble {
      padding: 14px 18px;
      border-radius: var(--radius);
      line-height: 1.65;
      font-size: 13.5px;
    }

    .message.assistant .bubble {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--ink);
      border-top-left-radius: 4px;
    }

    .message.user .bubble {
      background: var(--user-bg);
      color: var(--user-ink);
      border-top-right-radius: 4px;
    }

    /* ── IMAGES IN CHAT ───────────────────────────────── */
    .chat-image {
      display: block;
      max-width: 100%;
      width: 400px;
      border-radius: 10px;
      margin-top: 12px;
      border: 1px solid var(--border);
    }

    /* ── PROJECT CARD IN CHAT ─────────────────────────── */
    .project-card {
      margin-top: 14px;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--bg);
    }

    .project-card img {
      width: 100%;
      max-height: 200px;
      object-fit: cover;
      display: block;
      border-bottom: 1px solid var(--border);
    }

    .project-card-body {
      padding: 12px 14px;
    }

    .project-card-name {
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 4px;
    }

    .project-card-desc {
      font-size: 12px;
      color: var(--ink2);
      margin-bottom: 8px;
    }

    .project-card-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .project-card-tech span {
      font-size: 10px;
      padding: 2px 7px;
      border: 1px solid var(--border);
      border-radius: 99px;
      color: var(--ink3);
    }

    .project-card-link {
      display: inline-block;
      margin-top: 8px;
      font-size: 11px;
      color: var(--accent);
      text-decoration: none;
    }

    .project-card-link:hover { text-decoration: underline; }

    /* ── TYPING INDICATOR ─────────────────────────────── */
    .typing-indicator {
      display: flex;
      gap: 12px;
      align-items: center;
      animation: fadeUp 0.3s ease both;
    }

    .typing-dots {
      display: flex;
      gap: 5px;
      padding: 14px 18px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      border-top-left-radius: 4px;
    }

    .typing-dots span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--ink3);
      animation: dot-bounce 1.2s infinite;
    }

    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes dot-bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-6px); }
    }

    /* ── INPUT AREA ───────────────────────────────────── */
    .input-area {
      padding: 20px 32px 28px;
      border-top: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }

    .input-row {
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }

    #user-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg);
      color: var(--ink);
      font-family: var(--mono);
      font-size: 13.5px;
      resize: none;
      outline: none;
      min-height: 46px;
      max-height: 140px;
      transition: border-color 0.15s;
      line-height: 1.5;
    }

    #user-input:focus { border-color: var(--accent); }
    #user-input::placeholder { color: var(--ink3); }

    #send-btn {
      width: 46px;
      height: 46px;
      border-radius: var(--radius);
      background: var(--accent);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s;
      flex-shrink: 0;
      color: white;
    }

    #send-btn:hover { background: var(--accent2); }
    #send-btn:disabled { background: var(--border); cursor: not-allowed; }

    #send-btn svg { width: 18px; height: 18px; }

    .input-hint {
      font-size: 11px;
      color: var(--ink3);
      margin-top: 8px;
      text-align: center;
    }

    /* ── RESPONSIVE ───────────────────────────────────── */
    @media (max-width: 700px) {
      .app { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
  </style>
</head>
<body>

<div class="app">

  <!-- ── SIDEBAR ──────────────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="avatar-wrap">
      <div class="avatar-placeholder" id="avatar-placeholder">✦</div>
      <img id="avatar-img" src="" alt="avatar" style="display:none"
           onload="this.style.display='block'; document.getElementById('avatar-placeholder').style.display='none'"
           onerror="this.style.display='none'" />
    </div>

    <div class="sidebar-name" id="sidebar-name">—</div>
    <div class="sidebar-role" id="sidebar-role">—</div>
    <div class="sidebar-tagline" id="sidebar-tagline">—</div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section-label">Skills</div>
    <div id="skills-container"></div>

    <div class="sidebar-divider"></div>

    <nav class="sidebar-links" id="sidebar-links"></nav>
  </aside>

  <!-- ── MAIN ─────────────────────────────────────────── -->
  <main class="main">

    <header class="header">
      <div class="header-left">
        <div class="status-dot"></div>
        <div class="header-title">Chat with <strong id="header-name">—</strong></div>
      </div>
      <button class="clear-btn" onclick="clearChat()">Clear chat</button>
    </header>

    <div class="messages" id="messages">
      <div class="welcome" id="welcome">
        <div class="welcome-headline" id="welcome-headline">Ask me anything.</div>
        <div class="welcome-sub" id="welcome-sub">I'm an AI version of — here to answer your questions.</div>
        <div class="suggestions" id="suggestions"></div>
      </div>
    </div>

    <div class="input-area">
      <div class="input-row">
        <textarea id="user-input" placeholder="Ask me something..." rows="1"></textarea>
        <button id="send-btn" onclick="handleSend()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>
      <div class="input-hint">Press Enter to send · Shift+Enter for new line</div>
    </div>

  </main>
</div>

<!-- Load your content file -->
<script src="myContent.js"></script>

<script>
// ── INIT ─────────────────────────────────────────────────
const content = MY_PORTFOLIO_CONTENT;
let conversationHistory = [];
let isLoading = false;

// ── POPULATE SIDEBAR ─────────────────────────────────────
function initSidebar() {
  const { profile, skills } = content;

  document.getElementById('sidebar-name').textContent   = profile.name;
  document.getElementById('sidebar-role').textContent   = profile.role;
  document.getElementById('sidebar-tagline').textContent = profile.tagline;
  document.getElementById('header-name').textContent    = profile.name;
  document.getElementById('welcome-headline').textContent = `Ask me anything.`;
  document.getElementById('welcome-sub').textContent    = `I'm an AI version of ${profile.name} — here to answer your questions.`;
  document.title = `${profile.name} — Portfolio`;

  // Avatar
  if (content.images?.avatar) {
    document.getElementById('avatar-img').src = content.images.avatar;
  }

  // Skills
  const container = document.getElementById('skills-container');
  Object.entries(skills).forEach(([group, items]) => {
    const div = document.createElement('div');
    div.className = 'skills-group';
    div.innerHTML = `
      <div class="skills-group-name">${group.replace('_', ' ')}</div>
      <div class="skills-list">${items.map(s => `<span class="skill-tag">${s}</span>`).join('')}</div>
    `;
    container.appendChild(div);
  });

  // Links
  const linksEl = document.getElementById('sidebar-links');
  const links = [
    { icon: '✉', label: profile.email,    href: `mailto:${profile.email}` },
    { icon: '⌥', label: 'GitHub',         href: profile.github },
    { icon: '⊞', label: 'LinkedIn',       href: profile.linkedin },
  ].filter(l => l.href && !l.href.includes('undefined'));

  links.forEach(l => {
    const a = document.createElement('a');
    a.className = 'sidebar-link';
    a.href = l.href;
    a.target = '_blank';
    a.innerHTML = `<em class="link-icon">${l.icon}</em> ${l.label}`;
    linksEl.appendChild(a);
  });

  // Suggested questions
  const suggestionsEl = document.getElementById('suggestions');
  content.suggestedQuestions.forEach(q => {
    const btn = document.createElement('button');
    btn.className = 'suggestion-chip';
    btn.textContent = q;
    btn.onclick = () => {
      document.getElementById('user-input').value = q;
      handleSend();
    };
    suggestionsEl.appendChild(btn);
  });
}

// ── BUILD SYSTEM PROMPT ──────────────────────────────────
function buildSystemPrompt() {
  const { profile, qna, projects, skills } = content;

  const qnaText = qna.map(item =>
    `Q: ${item.question}\nA: ${item.answer}`
  ).join('\n\n');

  const projectsText = projects.map(p =>
    `• ${p.name} (${p.year}): ${p.description}
   Tech: ${p.tech.join(', ')}
   ${p.highlights || ''}
   ${p.url ? 'URL: ' + p.url : ''}
   ${p.image ? '[Has image: ' + p.name.toLowerCase().replace(/\s+/g, '_') + ']' : ''}`
  ).join('\n\n');

  return `You are the conversational portfolio AI for ${profile.name}, a ${profile.role} based in ${profile.location}.

RULES:
- For questions in the Q&A bank, use those answers closely. You can rephrase slightly but keep the spirit.
- Keep answers warm, honest, and concise — 2 to 4 sentences unless more detail is genuinely needed.
- When discussing a project that has an image, include [SHOW_PROJECT: project_name] at the end of your response (use the project name exactly as written).
- If asked something outside your knowledge, say you're not sure but offer contact via ${profile.email}.
- Never claim to be a human. You're an AI built to represent ${profile.name}.
- Don't use excessive formatting — write naturally, like a person would.

PROFILE:
Name: ${profile.name}
Role: ${profile.role}
Location: ${profile.location}
Tagline: ${profile.tagline}
Availability: ${profile.availability}
Email: ${profile.email}

SKILLS:
${JSON.stringify(skills, null, 2)}

Q&A BANK (use these answers):
${qnaText}

PROJECTS:
${projectsText}`;
}

// ── SEND MESSAGE ─────────────────────────────────────────
async function handleSend() {
  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if (!text || isLoading) return;

  input.value = '';
  input.style.height = 'auto';
  hideWelcome();

  appendMessage('user', text);
  conversationHistory.push({ role: 'user', content: text });

  showTyping();
  isLoading = true;
  document.getElementById('send-btn').disabled = true;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: buildSystemPrompt(),
        messages: conversationHistory,
      }),
    });

    const data = await response.json();

    if (data.error) throw new Error(data.error.message);

    const reply = data.content[0].text;
    conversationHistory.push({ role: 'assistant', content: reply });

    removeTyping();
    appendMessage('assistant', reply);

  } catch (err) {
    removeTyping();
    appendMessage('assistant', `Sorry, something went wrong: ${err.message}. Please check that your API key is configured.`);
  }

  isLoading = false;
  document.getElementById('send-btn').disabled = false;
}

// ── RENDER MESSAGE ───────────────────────────────────────
function appendMessage(role, text) {
  const messagesEl = document.getElementById('messages');

  const wrap = document.createElement('div');
  wrap.className = `message ${role}`;

  const avatarEl = document.createElement('div');
  avatarEl.className = 'msg-avatar';
  avatarEl.textContent = role === 'assistant'
    ? content.profile.name.charAt(0)
    : 'You';

  const bubble = document.createElement('div');
  bubble.className = 'bubble';

  if (role === 'assistant') {
    // Check for project card trigger
    const projectMatch = text.match(/\[SHOW_PROJECT:\s*([^\]]+)\]/i);
    let cleanText = text.replace(/\[SHOW_PROJECT:[^\]]+\]/gi, '').trim();

    // Render text
    bubble.innerHTML = cleanText.replace(/\n/g, '<br>');

    // Render project card if triggered
    if (projectMatch) {
      const projectName = projectMatch[1].trim();
      const project = content.projects.find(p =>
        p.name.toLowerCase().includes(projectName.toLowerCase()) ||
        projectName.toLowerCase().includes(p.name.toLowerCase())
      );
      if (project) {
        const card = buildProjectCard(project);
        bubble.appendChild(card);
      }
    }
  } else {
    bubble.textContent = text;
  }

  wrap.appendChild(avatarEl);
  wrap.appendChild(bubble);
  messagesEl.appendChild(wrap);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

// ── PROJECT CARD ─────────────────────────────────────────
function buildProjectCard(project) {
  const card = document.createElement('div');
  card.className = 'project-card';

  let html = '';

  if (project.image) {
    html += `<img src="${project.image}" alt="${project.name}" onerror="this.style.display='none'" />`;
  }

  html += `
    <div class="project-card-body">
      <div class="project-card-name">${project.name} · ${project.year}</div>
      <div class="project-card-desc">${project.description}</div>
      <div class="project-card-tech">
        ${project.tech.map(t => `<span>${t}</span>`).join('')}
      </div>
      ${project.url ? `<a class="project-card-link" href="${project.url}" target="_blank">View project →</a>` : ''}
    </div>
  `;

  card.innerHTML = html;
  return card;
}

// ── TYPING INDICATOR ─────────────────────────────────────
function showTyping() {
  const messagesEl = document.getElementById('messages');
  const el = document.createElement('div');
  el.className = 'typing-indicator';
  el.id = 'typing';

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.style.background = 'var(--accent)';
  avatar.style.color = 'white';
  avatar.style.fontFamily = 'var(--serif)';
  avatar.style.fontSize = '16px';
  avatar.textContent = content.profile.name.charAt(0);

  el.innerHTML += `<div class="typing-dots"><span></span><span></span><span></span></div>`;
  el.prepend(avatar);

  messagesEl.appendChild(el);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function removeTyping() {
  const el = document.getElementById('typing');
  if (el) el.remove();
}

// ── UTILS ─────────────────────────────────────────────────
function hideWelcome() {
  const w = document.getElementById('welcome');
  if (w) w.remove();
}

function clearChat() {
  conversationHistory = [];
  const messagesEl = document.getElementById('messages');
  messagesEl.innerHTML = '';

  const welcome = document.createElement('div');
  welcome.className = 'welcome';
  welcome.id = 'welcome';
  welcome.innerHTML = `
    <div class="welcome-headline" style="font-family:var(--serif);font-size:36px;color:var(--ink);margin-bottom:10px">Ask me anything.</div>
    <div class="welcome-sub" style="font-size:13px;color:var(--ink2);margin-bottom:32px">I'm an AI version of ${content.profile.name} — here to answer your questions.</div>
    <div class="suggestions" id="suggestions"></div>
  `;
  messagesEl.appendChild(welcome);

  const suggestionsEl = document.getElementById('suggestions');
  content.suggestedQuestions.forEach(q => {
    const btn = document.createElement('button');
    btn.className = 'suggestion-chip';
    btn.textContent = q;
    btn.onclick = () => {
      document.getElementById('user-input').value = q;
      handleSend();
    };
    suggestionsEl.appendChild(btn);
  });
}

// ── KEYBOARD ─────────────────────────────────────────────
document.getElementById('user-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    handleSend();
  }
});

// Auto-resize textarea
document.getElementById('user-input').addEventListener('input', function () {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 140) + 'px';
});

// ── START ─────────────────────────────────────────────────
initSidebar();
</script>

</body>
</html>
